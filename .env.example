# ─────────────────────────────────────────────────────────────────────────────
# Risk Intelligence System — Environment Variables
# Copy this file: cp .env.example .env  and fill in real values.
# NEVER commit .env to source control — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Automated Risk Intelligence System"
APP_VERSION="1.0.0"
ENVIRONMENT="development"    # development | production
DEBUG=true

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite for local dev. Switch to a hosted PostgreSQL string for production.
# Free PostgreSQL options: Neon (neon.tech), Supabase, Railway.
# The app auto-converts postgresql:// to the pg8000 dialect (pure Python,
# no native binaries — required for Vercel serverless).
#
# Local SQLite:
DATABASE_URL=sqlite:///./risk_intelligence.db
#
# PostgreSQL (uncomment and set when deploying):
# DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# ── CORS / Frontend ────────────────────────────────────────────────────────────
# Set to your Vercel domain once deployed (no trailing slash).
FRONTEND_URL=http://localhost:3000
# FRONTEND_URL=https://your-app.vercel.app

# ── Risk Scoring Thresholds (adjustable without code changes) ──────────────────
MEDIUM_RISK_THRESHOLD=35.0
HIGH_RISK_THRESHOLD=55.0
VERY_HIGH_RISK_THRESHOLD=70.0
CRITICAL_RISK_THRESHOLD=85.0

# Component weights (must sum to 1.0)
CREDIT_HISTORY_WEIGHT=0.40
BEHAVIORAL_WEIGHT=0.30
EXPOSURE_WEIGHT=0.30

# ── Anomaly Detection ──────────────────────────────────────────────────────────
VELOCITY_WINDOW_MINUTES=60
VELOCITY_MAX_TRANSACTIONS=8
AML_REPORTING_THRESHOLD=10000.00
STRUCTURING_LOWER_BOUND=9000.00
STRUCTURING_MIN_COUNT=3
LOCATION_MISMATCH_WINDOW_HOURS=2.0

# ── Behavioral Analysis Window ────────────────────────────────────────────────
BEHAVIORAL_LOOKBACK_DAYS=90
RECENT_TRANSACTION_DAYS=30

# ── Exposure Thresholds ───────────────────────────────────────────────────────
HIGH_DTI_THRESHOLD=0.45
CRITICAL_DTI_THRESHOLD=0.60

# ── n8n Workflow Integration ──────────────────────────────────────────────────
# Base URL of your n8n instance.  Used by the Run Pipeline button in the UI.
N8N_BASE_URL=http://localhost:5678
# Webhook URL that the dashboard POSTs to when triggering the adverse-media scan.
N8N_WEBHOOK_URL=http://localhost:5678/webhook/adverse-media-scan
